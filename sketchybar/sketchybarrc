PLUGIN_DIR="$CONFIG_DIR/plugins"

sketchybar --bar position=top height=32.5 blur_radius=30 color=0x40000000

default=(
  padding_left=0
  padding_right=0
  icon.font="Maple Mono NF:Bold:17.0"
  label.font="Maple Mono NF:Bold:14.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=6
  icon.padding_right=0
  label.padding_left=6
  label.padding_right=6
)
sketchybar --default "${default[@]}"

sketchybar --add item os-icon left \
           --set os-icon icon= icon.padding_left=7 icon.padding_right=7 label.drawing=off icon.color=0xFFF9FAFB background.color=0xFF7E55B3 background.corner_radius=5 background.height=25 background.padding_right=6 background.border_width=2.5 background.border_color=0xDFFCE566

sketchybar --add item front_app left \
           --set front_app script="$PLUGIN_DIR/front_app.sh" \
           --subscribe front_app front_app_switched

sketchybar --add event aerospace_workspace_change
for sid in $(aerospace list-workspaces --all); do
    sketchybar --add item space.$sid left \
        --subscribe space.$sid aerospace_workspace_change \
        --set space.$sid \
        drawing=off \
        label="$sid" \
        icon.drawing=off \
        script="$CONFIG_DIR/plugins/aerospace.sh $sid"
done

sketchybar --add item clock right \
           --set clock update_freq=10 icon=  script="$PLUGIN_DIR/clock.sh" \
           --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
           --subscribe volume volume_change \
           --add item battery right \
           --set battery update_freq=60 label.color=0xFF66EB66 icon.color=0xFF66EB66  script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change

sketchybar --add alias "Control Center,WiFi" right \
           --set "Control Center,WiFi" background.padding_left=-10 background.padding_right=-16 alias.color=0xFFE1BEE9

# resource: CPU gold / RAM foam / SWAP iris — compact to prevent cutoff.
# Visual left→right = CPU, RAM, (SWAP when >0.5G used). Add SWAP first (rightmost).
sketchybar --add item resource.swap right \
           --set resource.swap icon=󰾴 icon.drawing=off icon.color=0xFF3E8FB0 label.color=0xFF3E8FB0 drawing=off \
           label.padding_left=1 label.padding_right=2
sketchybar --add item resource.ram right \
           --set resource.ram icon= icon.color=0xFF9CCFD8 label.color=0xFF9CCFD8
sketchybar --add item resource.cpu right \
           --set resource.cpu update_freq=2 icon= icon.color=0xFFF6C177 label.color=0xFFF6C177 \
           script="$PLUGIN_DIR/resource.lua"

sketchybar --update
