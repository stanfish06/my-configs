{{- if .has_ohmyzsh -}}
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
{{ end }}
(( $+commands[nvim] )) && export EDITOR=nvim
{{ if (and (eq .chezmoi.hostname "Stans-MacBook-Pro") .is_mac) }}
path+="/opt/homebrew/opt/libtool/libexec/gnubin"
{{ else if (and (eq .chezmoi.hostname "stanfish") .is_regular_linux) -}}
# hp arch laptop
{{ end }}
{{ if .has_ohmyzsh -}}
plugins=(git fzf zsh-vi-mode mise)
source $ZSH/oh-my-zsh.sh
(( $+commands[starship] )) && eval "$(starship init zsh)"
(( $+commands[zoxide] )) && eval "$(zoxide init zsh)"
(( $+commands[mise] )) && eval "$(mise activate zsh)"
(( $+commands[atuin] )) && eval "$(atuin init zsh)"
{{ end }}
{{ if (and (eq .chezmoi.hostname "Stans-MacBook-Pro") .is_mac) -}}
source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{ if .has_conda -}}
# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/opt/homebrew/Caskroom/miniconda/base/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh" ]; then
        . "/opt/homebrew/Caskroom/miniconda/base/etc/profile.d/conda.sh"
    else
        export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
    fi
fi
unset __conda_setup
# <<< conda initialize <<<
{{ end -}}
{{ else if (and (eq .chezmoi.hostname "stanfish") (eq .chezmoi.os "linux")) }}
# hp arch laptop
{{ end }}
if (( $+commands[eza] )); then
alias l="eza -1 --group-directories-first --icons=auto"
alias le="eza --group-directories-first --icons=auto"
alias led="eza --group-directories-last --icons=auto"
alias la="eza -a --group-directories-first --icons=auto"
alias larth="eza -lah --git -snew --group-directories-first --icons=auto"
alias ll="eza -lh --git --group-directories-first --icons=auto"
alias lla="eza -lah --git --group-directories-first --icons=auto"
alias lt="eza --tree --level=2 --group-directories-first --icons=auto"
alias lta="eza --tree --level=2 -a --group-directories-first --icons=auto"
fi
